# Variables prefixed with PUBLIC_ are generated into src/generated/env.ts
# and exposed as constants in the SDK. The PUBLIC_ prefix is stripped from the export name.
# e.g. PUBLIC_BASE_API_URL -> export const BASE_API_URL = '...'
PUBLIC_BASE_API_URL=http://localhost:3000

# Variables without the PUBLIC_ prefix are NOT generated into constants.
# They are only available via process.env at runtime.
API_KEY=your-api-key-here
